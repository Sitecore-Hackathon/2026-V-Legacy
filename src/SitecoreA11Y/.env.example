# Required for the accessibility scan AI (explanations/fixes)
OPENAI_API_KEY=your-openai-api-key

# When the app is embedded (e.g. in XM Cloud), the host's /api returns HTML, not your Next.js API.
# Set this to the full URL of your Next.js app so the scan calls your app's /api/scan-a11y.
# Example: https://your-app.vercel.app  or  https://your-domain.com
# If pages.context provides siteInfo.renderingEngineEndpointUrl, that is used first.
NEXT_PUBLIC_SCAN_API_BASE_URL=
